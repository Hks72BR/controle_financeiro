rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Só usuários autenticados podem ler e escrever
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }
    match /config/{configId} {
      allow read, write: if request.auth != null;
    }
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
