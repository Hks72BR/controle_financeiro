# Token do bot Telegram (obtenha com @BotFather no Telegram)
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI

# Credenciais do bot para Firebase Auth
BOT_EMAIL=bot@financascoelho.app
BOT_PASSWORD=SuaSenhaAqui

# ==== MONITORAMENTO ====

# Porta do health check (para monitoramento externo)
HEALTH_PORT=3000

# Seu Chat ID do Telegram para receber notificações (obtenha com @userinfobot)
# O bot vai te avisar quando iniciar, parar ou tiver erro
ADMIN_CHAT_ID=

# ==== PLUGGY OPEN FINANCE ====
# Crie conta em: https://dashboard.pluggy.ai/signup
PLUGGY_CLIENT_ID=seu_client_id_aqui
PLUGGY_CLIENT_SECRET=seu_client_secret_aqui

# ==== GEMINI AI (Google) ====
# Crie chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_gemini_api_key_aqui

# ==== SERVIDOR ====
PORT=3000
NODE_ENV=development
